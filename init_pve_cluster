def remote_network_scan(ip, password):
    script = """
    import os, subprocess, json, socket, re
    
    def extract_num(name):
        n = ''.join(filter(str.isdigit, name))
        return int(n) if n else 999

    print("\\033[0;36mPhysical Interfaces:\\033[0m")
    try:
        ifaces = [f for f in os.listdir('/sys/class/net') if not re.match(r'^(lo|vmbr|tap|veth|fw|bond|vlan)', f)]
        ifaces.sort(key=extract_num)
        
        for iface in ifaces:
            subprocess.run(['ip', 'link', 'set', iface, 'up'], stderr=subprocess.DEVNULL)
        
        for iface in ifaces:
            try:
                with open(f'/sys/class/net/{iface}/carrier', 'r') as f: carrier = f.read().strip()
            except: carrier = "0"
            state = "\\033[0;32mConnected\\033[0m" if carrier == "1" else "\\033[0;31mDisconnected\\033[0m"
            
            try:
                with open(f'/sys/class/net/{iface}/speed', 'r') as f: speed = f"{f.read().strip()} Mbps"
            except: speed = "N/A"
                
            master_info = "Free"
            if os.path.exists(f'/sys/class/net/{iface}/master'):
                master_name = os.path.basename(os.readlink(f'/sys/class/net/{iface}/master'))
                master_info = f"\\033[1;33mSlaved to {master_name}\\033[0m"
                
            print(f"  - {iface.ljust(6)} | Link: {state.ljust(21)} | Speed: {speed.ljust(10)} | Status: {master_info}")
    except Exception as e:
        print(f"Error reading physical interfaces: {e}")

    print("\\n\\033[0;36mVirtual Bridges (vmbr):\\033[0m")
    try:
        node = socket.gethostname()
        out = subprocess.check_output(['pvesh', 'get', f'/nodes/{node}/network', '--type', 'bridge', '--output-format', 'json'])
        data = json.loads(out)
        data.sort(key=lambda x: extract_num(x.get('iface', '')))
        
        for i in data:
            name = i.get('iface', '')
            ports = i.get('bridge_ports', 'none')
            addr = i.get('address', '')
            mask = i.get('netmask', '')
            ip_str = f"{addr}/{mask}" if addr else "No IP"
            gw = f" | GW: {i.get('gateway')}" if i.get('gateway') else ""
            
            comment = i.get('comments', '')
            if not comment:
                try:
                    c_out = subprocess.check_output(f"grep -A 10 '^auto {name}' /etc/network/interfaces | grep '^#' | head -n 1", shell=True, text=True)
                    comment = c_out.strip().lstrip('#').strip()
                except: pass
            
            comment = str(comment).replace('\\n', ' ').replace('\\r', '').strip()
            if not comment: comment = 'N/A'
            print(f"  - {name.ljust(6)} | Ports: \\033[1;33m{ports.ljust(10)}\\033[0m | IP: {ip_str}{gw} | Note: \\033[0;32m{comment}\\033[0m")
    except Exception as e:
        print(f"API Error: {e}")
    """
    code, stdout, _ = run_remote_python(ip, password, script)
    print(stdout, end="")

