                        break
                    except: print_color(RED, "Invalid format.")
                
                print_color(NC, "  -> Deploying GUI compliant configuration... ", end='')
                params = {"action": "create", "iface": new_vmbr, "comment": br_comment, "address": new_cidr, "gateway": "", "ports": phys_iface, "vlan_aware": br_vlan, "vids": br_vids, "mtu": br_mtu}
                run_remote_python(ip, current_password, REMOTE_NET_WRITER, params)
                run_ssh(ip, current_password, "ifreload -a > /dev/null 2>&1")
                print_color(GREEN, "Done.")

            elif net_choice == 1:
                print_color(CYAN, "\n  [Modify Bridge]")
                bridges = fetch_bridge_list(ip, current_password)
                if not bridges:
                    print_color(YELLOW, "  No bridges found to modify."); continue
                
                opts = [b["display"] for b in bridges] + ["Cancel"]
                print()
                br_idx = tui_menu("  Select a bridge to modify:", opts)
                if br_idx == len(bridges): continue
                
                mod_vmbr = bridges[br_idx]["name"]
                fetch_script = f"""
                import subprocess, json, socket
                try:
                    node = socket.gethostname()
                    out = subprocess.check_output(['pvesh', 'get', f'/nodes/{{node}}/network/{mod_vmbr}', '--output-format', 'json'])
                    d = json.loads(out)
                    comment = d.get('comments', '')
                    if not comment:
                        try:
                            c_out = subprocess.check_output(f"grep -A 10 '^auto {mod_vmbr}' /etc/network/interfaces | grep '^#' | head -n 1", shell=True, text=True)
                            comment = c_out.strip().lstrip('#').strip()
                        except: pass
                    
                    comment = str(comment).replace('\\n', ' ').replace('\\r', '').strip()
                    res = {{
                        "comment": comment,
                        "cidr": f"{{d.get('address', '')}}/{{d.get('netmask', '')}}" if d.get('address') else "",
                        "ports": d.get('bridge_ports', ''),
                        "vlan": 'Y' if d.get('bridge_vlan_aware') else 'N',
                        "mtu": d.get('mtu', ''),
                        "vids": d.get('bridge_vids', '2-4094'),
                        "gw": d.get('gateway', '')
                    }}
                    print("PVE_DATA::" + json.dumps(res))
                except: print("PVE_DATA::{{}}")
                """
                _, raw_data, _ = run_remote_python(ip, current_password, fetch_script)
                try:
                    json_str = [line for line in raw_data.split('\n') if line.startswith("PVE_DATA::")][0].replace("PVE_DATA::", "")
                    d = json.loads(json_str)
                except: d = {}

                new_comment = input_prefill("  Description/Comment : ", d.get('comment', '')).replace('"', '')
                new_ports = input_prefill("  Interface(s) : ", d.get('ports', '')).replace(',', ' ').strip()
                
                print()
                def_vlan_idx = 1 if d.get('vlan') == 'Y' else 0
                new_vlan_opt = tui_menu("  VLAN aware?", ["No", "Yes"], orientation="horizontal", default_idx=def_vlan_idx)
                new_vlan = "Y" if new_vlan_opt == 1 else "N"
                
                new_vids = d.get('vids', '2-4094')
                if new_vlan == "Y":
                    new_vids = input_prefill("  Allowed VLAN(s) : ", new_vids)
                    
                new_mtu = input_prefill("  MTU (empty = 1500) : ", str(d.get('mtu', '')))
                new_cidr = input_prefill("  IP/CIDR (empty = manual) : ", d.get('cidr', ''))
                
                new_gw = d.get('gw', '')
                if new_gw:
                    new_gw = input_prefill("  Gateway : ", new_gw)
                    
                print_color(NC, "  -> Perfect atomic file update... ", end='')
                params = {"action": "modify", "iface": mod_vmbr, "comment": new_comment, "address": new_cidr, "gateway": new_gw, "ports": new_ports, "vlan_aware": new_vlan, "vids": new_vids, "mtu": new_mtu}
                run_remote_python(ip, current_password, REMOTE_NET_WRITER, params)
                run_ssh(ip, current_password, "ifreload -a > /dev/null 2>&1")
                print_color(GREEN, "Done.")

            elif net_choice == 2:
                print_color(CYAN, "\n  [Delete Bridge]")
                bridges = fetch_bridge_list(ip, current_password)
                if not bridges:
                    print_color(YELLOW, "  No bridges found to delete."); continue
                
                opts = [b["display"] for b in bridges] + ["Cancel"]
                print()
                br_idx = tui_menu("  Select a bridge to delete:", opts)
                if br_idx == len(bridges): continue
                
                br_to_del = bridges[br_idx]["name"]
                _, mgt_iface_raw, _ = run_ssh(ip, current_password, f"ip -o -4 addr show | grep -w '{ip}' | awk '{{print $2}}' | head -n 1")
                mgt_iface = mgt_iface_raw.strip()
                if br_to_del == mgt_iface:
                    print_color(RED, f"Action blocked: {br_to_del} carries the active management IP ({ip}). Deleting it would sever the connection.")
                else:
                    print_color(NC, f"  -> Destroying {br_to_del}... ", end='')
                    params = {"action": "delete", "iface": br_to_del}
                    run_remote_python(ip, current_password, REMOTE_NET_WRITER, params)
                    print_color(GREEN, "Done.")

            elif net_choice == 3:
                break

        print_color(YELLOW, f"\n  Corosync Role Assignment for {host}")
        ip_list = fetch_ip_list(ip, current_password)
        if not ip_list:
            print_color(RED, "Fatal: No IPs found on the server.")
            sys.exit(1)

        opts = [i["display"] for i in ip_list] + ["Manual Entry"]
        def_idx = 0
        
        if not global_cidr_subnet:
            print()
            c_idx = tui_menu("Select Corosync IP:", opts)
            if c_idx == len(ip_list):
                c_input = input_prefill("  Enter Corosync IP : ", ip)
                c_ip = c_input.split('/')[0]
                matched_cidr = next((i["ip"] for i in ip_list if i["ip"].startswith(f"{c_ip}/")), None)
                if not matched_cidr:
                    print_color(RED, "IP not assigned locally. Assuming /24 subnet.")
                    global_cidr_subnet = str(ipaddress.ip_interface(f"{c_ip}/24").network)
                else: global_cidr_subnet = str(ipaddress.ip_interface(matched_cidr).network)
            else:
                c_ip = ip_list[c_idx]["ip"].split('/')[0]
                global_cidr_subnet = str(ipaddress.ip_interface(ip_list[c_idx]["ip"]).network)
        else:
            for i, item in enumerate(ip_list):
                try:
                    if ipaddress.ip_interface(item["ip"]).network == ipaddress.ip_network(global_cidr_subnet):
                        def_idx = i
                        break
                except: pass
                
            suggested_ip = str(ipaddress.IPv4Address(prev_c_ip) + 1) if prev_c_ip else ""
            print(f"  Expected cluster network: {global_cidr_subnet}")
            
            print()
            c_idx = tui_menu("Select Corosync IP:", opts, default_idx=def_idx)
            if c_idx == len(ip_list):
                c_input = input_prefill("  Enter Corosync IP : ", suggested_ip)
                c_ip = c_input.split('/')[0]
            else:
                c_ip = ip_list[c_idx]["ip"].split('/')[0]

        prev_c_ip = c_ip
        nodes.append(Node(ip, host, current_password, c_ip))
        last_password = current_password
        node_idx += 1

    print_color(CYAN, "\n====================================================")
    while True:
        cluster_name = input_prefill("Cluster Name (e.g., datacenter1) : ")
        if not cluster_name: print_color(RED, "Required.")
        elif not cluster_name.replace('_', '').replace('-', '').isalnum(): print_color(RED, "Alphanumeric only.")
        else: break

    first_node = nodes[0]

    print_color(YELLOW, "\n[1/7] Corosync Full-Mesh Connectivity Test...")
    all_ok = True
    for i, source in enumerate(nodes):
        for j, target in enumerate(nodes):
            if i != j:
                print_color(NC, f"  -> Ping: {source.hostname} -> {target.corosync_ip} ... ", end='')
                code, _, _ = run_ssh(source.ip, source.password, f"ping -c 1 -W 2 {target.corosync_ip}")
                if code == 0: print_color(GREEN, "OK")
                else: print_color(RED, "FAILED"); all_ok = False
                    
    if not all_ok:
        print_color(RED, "Network not routable. (Ctrl+C for Rollback)")
        sys.exit(1)

    print_color(YELLOW, "\n[2/7] Repositories and dependencies...")
    repo_script = """
    export DEBIAN_FRONTEND=noninteractive
    rm -f /etc/apt/sources.list.d/pve-enterprise.* /etc/apt/sources.list.d/ceph.* 2>/dev/null || true
    sed -i '/enterprise.proxmox.com/d' /etc/apt/sources.list /etc/apt/sources.list.d/* 2>/dev/null || true
    CODENAME=$(grep "VERSION_CODENAME=" /etc/os-release | cut -d'=' -f2 || echo "trixie")
    echo "deb http://download.proxmox.com/debian/pve $CODENAME pve-no-subscription" > /etc/apt/sources.list.d/pve-no-subscription.list
    apt-get update -qq > /dev/null
    apt-get install -yq expect jq multipath-tools > /dev/null
    """
    
    for node in nodes:
        print_color(NC, f"  -> Configuring {node.hostname}... ", end='')
        run_ssh(node.ip, node.password, "systemctl start pve-cluster 2>/dev/null || true")
        run_ssh(node.ip, node.password, repo_script)
        for target in nodes: run_ssh(node.ip, node.password, f"sed -i '/{target.ip}/d' /etc/hosts")
        hosts_injection = "\n".join([f"echo '{n.ip} {n.hostname} # PVE_CLUSTER' >> /etc/hosts" for n in nodes])
        run_ssh(node.ip, node.password, hosts_injection)
        print_color(GREEN, "OK")

    print_color(YELLOW, f"\n[3/7] Creating cluster '{cluster_name}'... ", end='')
    run_ssh(first_node.ip, first_node.password, f"pvecm create {cluster_name} --link0 {first_node.corosync_ip}")
    print_color(GREEN, "OK")

    print_color(YELLOW, "\n[4/7] Joining nodes to cluster...")
    for node in nodes[1:]:
        print_color(NC, f"  -> Integrating {node.hostname}... ", end='')
        reset_cmd = "systemctl stop pve-cluster corosync 2>/dev/null || true; killall -9 pmxcfs 2>/dev/null || true; umount -l /etc/pve 2>/dev/null || true; rm -rf /var/lib/pve-cluster/config.db /var/lib/pve-cluster/.pve-lock 2>/dev/null || true; rm -rf /etc/corosync/* /var/lib/corosync/* /etc/pve/corosync.conf 2>/dev/null || true; systemctl start pve-cluster; sleep 3"
        run_ssh(node.ip, node.password, reset_cmd)
        
        safe_master_pass = first_node.password.replace("'", "'\\''")
        expect_script = textwrap.dedent(f"""
        set timeout 120
        set master_pass $env(MASTER_PASS)
        spawn pvecm add {first_node.ip} -link0 {node.corosync_ip}
        expect {{
            -re ".*(yes/no).*\\\\?" {{ send "yes\\r"; exp_continue }}
            -re "(?i)password.*:" {{ send "$master_pass\\r"; exp_continue }}
            eof
        }}
        catch wait result
        exit [lindex $result 3]
        """)
        
        b64_expect = base64.b64encode(expect_script.encode()).decode()
        join_cmd = f"export MASTER_PASS='{safe_master_pass}'; echo '{b64_expect}' | base64 -d | expect"
        
        code, out, err = run_ssh(node.ip, node.password, join_cmd)
        
        if code == 0:
            print_color(GREEN, "Success")
        else:
            print_color(RED, "FAILED")
            print_color(YELLOW, "--- Error Logs ---")
            print(out)
            print(err)
            sys.exit(1)

    print_color(YELLOW, "\n[5/7] QDevice Configuration...")
    if len(nodes) == 2:
        qip = input_prefill("  QDevice IP (Empty to skip) : ")
        if qip:
            while True:
                qpass = getpass.getpass("  QDevice Root Password : ")
                if not qpass: print_color(RED, "Password required."); continue
                break
                
            for node in nodes:
                run_ssh(node.ip, node.password, "export DEBIAN_FRONTEND=noninteractive; apt-get install -yq corosync-qdevice > /dev/null")
                
            expect_qdev = textwrap.dedent(f"""
            set timeout 120
            set qpass $env(QPASS)
            spawn pvecm qdevice setup {qip} -force
            expect {{
                ".*yes/no.*" {{ send "yes\\r"; exp_continue }}
                "(?i)password.*:" {{ send "$qpass\\r"; exp_continue }}
                eof
            }}
            """)
            safe_qpass = qpass.replace("'", "'\\''")
            b64_qdev = base64.b64encode(expect_qdev.encode()).decode()
            qdev_cmd = f"export QPASS='{safe_qpass}'; echo '{b64_qdev}' | base64 -d | expect"
            
            run_ssh(first_node.ip, first_node.password, qdev_cmd)
            print_color(GREEN, "  -> QDevice registered successfully.")
    else:
        print("  Not required (More than 2 nodes detected).")

    print_color(YELLOW, "\n[6/7] Global Datacenter Options...")
    _, current_mig, _ = run_ssh(first_node.ip, first_node.password, "grep -oP '(?<=^migration: ).*' /etc/pve/datacenter.cfg 2>/dev/null || echo 'Default'")
    
    mig_options = ["Keep current"]
    if global_cidr_subnet: mig_options.append(f"Dedicated Corosync Network ({global_cidr_subnet})")
    mig_options.append("Manual Entry (CIDR)")
    
    print()
    mig_choice_idx = tui_menu(f"Migration Network [Current: {current_mig.strip()}] :", mig_options)
    
    if mig_options[mig_choice_idx].startswith("Dedicated"):
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -migration type=secure,network={global_cidr_subnet}")
    elif mig_options[mig_choice_idx].startswith("Manual"):
        custom_mig = input_prefill("    CIDR : ")
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -migration type=secure,network={custom_mig}")

    _, current_ha, _ = run_ssh(first_node.ip, first_node.password, "grep -oP '(?<=^ha: ).*' /etc/pve/datacenter.cfg 2>/dev/null || echo 'Default (conditional)'")
    ha_opts = [
        "Keep current configuration",
        "conditional (Migrate if available, else freeze)",
        "migrate     (Force migration on shutdown)",
        "freeze      (Leave VMs/CTs in place)",
        "failover    (Hard stop and restart elsewhere)"
    ]
    
    print()
    ha_choice = tui_menu(f"HA Strategy [Current: {current_ha.strip()}] :", ha_opts)
    
    if ha_choice != 0:
        policies = ["", "conditional", "migrate", "freeze", "failover"]
        sel_policy = policies[ha_choice]
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -ha shutdown_policy={sel_policy}")
        print_color(GREEN, f"    -> Applied: {sel_policy}")

    print_color(YELLOW, "\n[7/7] Asynchronous System Updates (screen)...")
    print()
    do_update = tui_menu("Launch dist-upgrade across all nodes?", ["No, skip", "Yes, start updates"], orientation="horizontal")
    if do_update == 1:
        for node in nodes:
            run_ssh(node.ip, node.password, "export DEBIAN_FRONTEND=noninteractive; apt-get update -qq > /dev/null && apt-get install -yq screen > /dev/null")
            update_cmd = "export DEBIAN_FRONTEND=noninteractive; echo '--- UPGRADE START ---' > /root/pve_update.log; apt-get dist-upgrade -y >> /root/pve_update.log 2>&1; echo '--- FINISHED ---' >> /root/pve_update.log; exec bash"
            run_ssh(node.ip, node.password, f"screen -dmS pve_upgrade bash -c \"{update_cmd}\"")
        print_color(CYAN, "  Tracking: login to nodes and type 'screen -r pve_upgrade'")

    print_color(GREEN, "\nCLUSTER INITIALIZATION COMPLETED SUCCESSFULLY!")
    _, status, _ = run_ssh(first_node.ip, first_node.password, "pvecm status")
    for line in status.split('\n'):
        if any(kw in line for kw in ["Quorum", "Nodes", "Name", "Node IP"]):
            print(line)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        handle_rollback()
