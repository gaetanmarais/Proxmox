        run_ssh(node.ip, node.password, repo_script)
        for target in nodes: run_ssh(node.ip, node.password, f"sed -i '/{target.ip}/d' /etc/hosts")
        hosts_injection = "\n".join([f"echo '{n.ip} {n.hostname} # PVE_CLUSTER' >> /etc/hosts" for n in nodes])
        run_ssh(node.ip, node.password, hosts_injection)
        print_color(GREEN, "OK")

    # --- 5. CREATE CLUSTER ---
    if not first_node.has_cluster:
        print_color(YELLOW, f"\n[3/8] Creating cluster '{global_cluster_name}'... ", end='')
        run_ssh(first_node.ip, first_node.password, f"pvecm create {global_cluster_name} --link0 {first_node.corosync_ip}")
        print_color(GREEN, "OK")
    else: print_color(YELLOW, f"\n[3/8] Cluster '{global_cluster_name}' already exists on {first_node.hostname}. Skipping creation.")

    # --- 6. JOIN NODES ---
    print_color(YELLOW, "\n[4/8] Joining nodes to cluster...")
    for node in nodes[1:]:
        if node.has_cluster:
            _, out, _ = run_ssh(node.ip, node.password, "grep -oP '(?<=cluster_name: ).*' /etc/pve/corosync.conf 2>/dev/null")
            if out.strip() == global_cluster_name: print_color(GREEN, f"  -> {node.hostname} already joined."); continue
            else: print_color(RED, f"  -> {node.hostname} is in a DIFFERENT cluster."); sys.exit(1)

        print_color(NC, f"  -> Integrating {node.hostname}... ", end='')
        reset_cmd = "systemctl stop pve-cluster corosync 2>/dev/null || true; killall -9 pmxcfs 2>/dev/null || true; umount -l /etc/pve 2>/dev/null || true; rm -rf /var/lib/pve-cluster/config.db /var/lib/pve-cluster/.pve-lock 2>/dev/null || true; rm -rf /etc/corosync/* /var/lib/corosync/* /etc/pve/corosync.conf 2>/dev/null || true; systemctl start pve-cluster; sleep 3"
        run_ssh(node.ip, node.password, reset_cmd)
        
        safe_master_pass = first_node.password or last_password
        if not safe_master_pass:
            safe_master_pass = getpass.getpass(f"  -> [Required] Root password for {first_node.hostname} to join cluster: ")
            last_password = safe_master_pass
        
        expect_script = textwrap.dedent(f"""
        set timeout 120
        set master_pass $env(MASTER_PASS)
        spawn pvecm add {first_node.ip} -link0 {node.corosync_ip}
        expect {{
            -re ".*(yes/no).*\\\\?" {{ send "yes\\r"; exp_continue }}
            -re "(?i)password.*:" {{ send "$master_pass\\r"; exp_continue }}
            eof
        }}
        catch wait result
        exit [lindex $result 3]
        """)
        b64_expect = base64.b64encode(expect_script.encode()).decode()
        safe_qpass = safe_master_pass.replace("'", "'\\''")
        join_cmd = f"export MASTER_PASS='{safe_qpass}'; echo '{b64_expect}' | base64 -d | expect > /dev/null 2>&1"
        code, out, err = run_ssh(node.ip, node.password, join_cmd)
        
        if code == 0: print_color(GREEN, "Success")
        else: print_color(RED, "FAILED\n" + out + err); sys.exit(1)

    # --- 7. QDEVICE AUTO-HEAL ---
    print_color(YELLOW, "\n[5/8] QDevice Configuration...")
    _, pvecm_out, _ = run_ssh(first_node.ip, first_node.password, "pvecm status")
    
    try: cluster_nodes = int(re.search(r'Nodes:\s+(\d+)', pvecm_out).group(1))
    except: cluster_nodes = len(nodes)
    
    has_qdevice = "Qdevice information" in pvecm_out or "Qdevice" in pvecm_out
    qdevice_active_ip = None
    qdevice_hostname = "QDEVICE"
    
    _, qdev_ip_out, _ = run_ssh(first_node.ip, first_node.password, "grep -oP '(?<=host: ).*' /etc/pve/corosync.conf 2>/dev/null")
    if qdev_ip_out.strip(): 
        qdevice_active_ip = qdev_ip_out.strip().replace('"', '').replace("'", "")
        try:
            _, q_host_out, _ = run_ssh(first_node.ip, first_node.password, f"getent hosts {qdevice_active_ip} | awk '{{print $2}}'")
            if q_host_out.strip(): qdevice_hostname = q_host_out.strip().split('\n')[0]
        except: pass

    if cluster_nodes % 2 == 0:
        if has_qdevice: print_color(GREEN, f"  -> QDevice already active for {cluster_nodes}-node cluster. Skipping.")
        else:
            print_color(CYAN, "  ℹ️  INFO: Your cluster currently has an EVEN number of nodes ({} nodes).".format(cluster_nodes))
            print_color(CYAN, "     A QDevice (Quorum Device) is strictly recommended to act as an external tie-breaker.")
            
            if tui_menu(f"\nConfigure a QDevice Witness for this {cluster_nodes}-node cluster?", ["No", "Yes"], orientation="horizontal") == 1:
                while True:
                    qip = input_prefill("  QDevice IP (Empty to skip) : ")
                    if not qip: break
                    fallback_qpass = last_qpass if last_qpass else last_password
                    prompt_str = "  QDevice Root Password (if empty, reuse cluster password): " if fallback_qpass else "  QDevice Root Password : "
                    qpass = getpass.getpass(prompt_str)
                    if not qpass:
                        if fallback_qpass: qpass = fallback_qpass
                        else: print_color(RED, "  Password required."); continue
                            
                    print_color(NC, "  -> Probing QDevice server... ", end='')
                    code, out, _ = run_ssh(qip, qpass, "echo \"QDEV_PROBE::$(hostname)::$([ -d /etc/corosync/qnetd ] && echo 1 || echo 0)\"")
                    if code != 0: print_color(RED, "Connection failed."); continue
                    try:
                        probe_res = [line for line in out.splitlines() if line.startswith("QDEV_PROBE::")][0]
                        _, q_hostname, q_state = probe_res.split("::")
                        print_color(GREEN, "Connected.")
                        qdevice_hostname = q_hostname
                    except: print_color(RED, "Probe failed."); continue
                        
                    print_color(CYAN, f"  Target QDevice identified as : \033[1;32m{q_hostname}\033[0;36m ({qip})")
                    if tui_menu(f"\nProceed with configuring {q_hostname} as QDevice?", ["No", "Yes"], orientation="horizontal", default_idx=1) == 0: continue
                    if q_state == "1" and tui_menu(f"\nPurge existing config on {q_hostname}?", ["No", "Yes"], orientation="horizontal", default_idx=1) == 0: continue
                            
                    last_qpass = qpass
                    print_color(NC, "  -> Preparing nodes... ", end='')
                    for node in nodes: run_ssh(node.ip, node.password, "export DEBIAN_FRONTEND=noninteractive; apt-get install -yq corosync-qdevice > /dev/null")
                    print_color(GREEN, "OK")
                    
                    print_color(NC, "  -> Auto-Healing target QDevice server... ", end='')
                    qdev_heal = "systemctl stop corosync-qnetd 2>/dev/null || true; apt-get purge -y corosync-qnetd 2>/dev/null || true; rm -rf /etc/corosync/qnetd/* /etc/corosync/qnetd.conf 2>/dev/null || true; apt-get install -yq corosync-qnetd > /dev/null; systemctl enable --now corosync-qnetd > /dev/null 2>&1 || true"
                    run_ssh(qip, qpass, qdev_heal)
                    run_ssh(first_node.ip, first_node.password, "pvecm qdevice remove 2>/dev/null || true; rm -rf /etc/corosync/qdevice/net/nssdb/* 2>/dev/null || true")
                    print_color(GREEN, "OK")
                    
                    print_color(NC, "  -> Registering QDevice... ", end='')
                    expect_qdev = textwrap.dedent(f"""
                    set timeout 120
                    set qpass $env(QPASS)
                    spawn pvecm qdevice setup {qip} -force
                    expect {{
                        -re ".*(yes/no).*\\\\?" {{ send "yes\\r"; exp_continue }}
                        -re "(?i)password.*:" {{ send "$qpass\\r"; exp_continue }}
                        eof
                    }}
                    catch wait result
                    exit [lindex $result 3]
                    """)
                    run_ssh(first_node.ip, first_node.password, f"ssh-keyscan -H {qip} >> /root/.ssh/known_hosts 2>/dev/null")
                    safe_qpass = qpass.replace("'", "'\\''")
                    b64_qdev = base64.b64encode(expect_qdev.encode()).decode()
                    qdev_cmd = f"export QPASS='{safe_qpass}'; echo '{b64_qdev}' | base64 -d | expect > /dev/null"
                    code, out, err = run_ssh(first_node.ip, first_node.password, qdev_cmd)
                    
                    _, check_out, _ = run_ssh(first_node.ip, first_node.password, "pvecm status")
                    if code == 0 and "Qdevice" in check_out:
                        print_color(GREEN, "Success"); qdevice_active_ip = qip
                    else: print_color(RED, "FAILED")
                    break
    else:
        if has_qdevice:
            print_color(YELLOW, f"\n  ⚠️  INFO: Your cluster currently has an ODD number of nodes ({cluster_nodes}).")
            print_color(CYAN, "     A QDevice is currently configured, but it is not necessary and could cause quorum issues.")
            
            if tui_menu(f"\nRemove the existing QDevice ({qdevice_active_ip})?", ["No, keep it", "Yes, remove it"], orientation="horizontal", default_idx=1) == 1:
                print_color(NC, "  -> Removing QDevice... ", end='')
                run_ssh(first_node.ip, first_node.password, "pvecm qdevice remove 2>/dev/null || true; rm -rf /etc/corosync/qdevice/net/nssdb/* 2>/dev/null || true")
                print_color(GREEN, "OK")
                qdevice_active_ip = None
                has_qdevice = False
        else:
            print_color(GREEN, f"  Not required ({cluster_nodes} is an odd number of nodes. Quorum naturally resolves ties).")

    # --- 8. DATACENTER OPTIONS ---
    print_color(YELLOW, "\n[6/8] Global Datacenter Options...")
    _, current_mig, _ = run_ssh(first_node.ip, first_node.password, "grep -oP '(?<=^migration: ).*' /etc/pve/datacenter.cfg 2>/dev/null || echo 'Default'")
    mig_options = ["Keep current", f"Dedicated Corosync Network ({global_cidr_subnet})", "Manual Entry (CIDR)"] if global_cidr_subnet else ["Keep current", "Manual Entry (CIDR)"]
    mig_choice_idx = tui_menu(f"\nMigration Network [Current: {current_mig.strip()}] :", mig_options)
    
    if mig_options[mig_choice_idx].startswith("Dedicated"): run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -migration type=secure,network={global_cidr_subnet}")
    elif mig_options[mig_choice_idx].startswith("Manual"):
        custom_mig = input_prefill("    CIDR : ")
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -migration type=secure,network={custom_mig}")

    _, current_ha, _ = run_ssh(first_node.ip, first_node.password, "grep -oP '(?<=^ha: ).*' /etc/pve/datacenter.cfg 2>/dev/null || echo 'Default (conditional)'")
    ha_opts = ["Keep current configuration", "conditional", "migrate", "freeze", "failover"]
    ha_choice = tui_menu(f"\nHA Strategy [Current: {current_ha.strip()}] :", ha_opts)
    if ha_choice != 0:
        sel_policy = ["", "conditional", "migrate", "freeze", "failover"][ha_choice]
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -ha shutdown_policy={sel_policy}")
        print_color(GREEN, f"    -> Applied: {sel_policy}")

    # --- 9. SYSTEM UPDATES ---
    print_color(YELLOW, "\n[7/8] Asynchronous System Updates (screen)...")
    if tui_menu("\nLaunch dist-upgrade across all nodes?", ["No, skip", "Yes, start updates"], orientation="horizontal") == 1:
        for node in nodes:
            run_ssh(node.ip, node.password, "export DEBIAN_FRONTEND=noninteractive; apt-get update -qq > /dev/null && apt-get install -yq screen > /dev/null")
            update_cmd = f"export DEBIAN_FRONTEND=noninteractive; echo '--- UPGRADE START ---' > /root/update_{node.hostname}.log; apt-get dist-upgrade -y >> /root/update_{node.hostname}.log 2>&1; echo '--- FINISHED ---' >> /root/update_{node.hostname}.log"
            run_ssh(node.ip, node.password, f"screen -dmS upg_{node.hostname} bash -c \"{update_cmd}\"")
        print_color(CYAN, "  Tracking: login to nodes and type 'screen -r' (sessions will auto-close when done)")

    # --- 10. GENERATE & PUBLISH SVG TOPOLOGY ---
    print_color(YELLOW, "\n[8/8] Generating Visual Cluster Topology (SVG)...")
    try:
        svg_content = generate_cluster_svg(global_cluster_name, nodes, qdevice_active_ip, global_cidr_subnet, qdevice_hostname)
        push_script = "mkdir -p /usr/share/pve-manager/images/; cat - | base64 -d > /usr/share/pve-manager/images/cluster.svg"
        b64_svg = base64.b64encode(svg_content.encode('utf-8')).decode('utf-8')
        
        for node in nodes: run_ssh(node.ip, node.password, "bash -c '" + push_script + "'", stdin_str=b64_svg)
        print_color(GREEN, "  -> SVG Topology successfully published on all nodes.")
        print()
        for node in nodes: print_color(CYAN, f"  🔗 Topology Link ({node.hostname}): \033[1;32mhttps://{node.ip}:8006/pve2/images/cluster.svg\033[0m")
    except Exception as e: print_color(RED, f"  Failed to generate SVG topology: {e}")

    print_color(GREEN, "\nCLUSTER INITIALIZATION COMPLETED SUCCESSFULLY!")
    _, status, _ = run_ssh(first_node.ip, first_node.password, "pvecm status")
    for line in status.split('\n'):
        if any(kw in line for kw in ["Quorum", "Nodes", "Name", "Node IP"]): print(line)

if __name__ == "__main__":
    try: main()
    except KeyboardInterrupt: handle_rollback()
