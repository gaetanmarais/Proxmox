def clean_network_bridges(ip, password):
    fetch_script = """
    import os, subprocess, json
    try:
        gw_iface = ""
        try:
            gw_out = subprocess.check_output("ip route show default | head -n 1 | awk '{print $5}'", shell=True, text=True).strip()
            gw_iface = gw_out
        except: pass
        
        br_list = [f for f in os.listdir('/sys/class/net') if f.startswith('vmbr')]
        protected = set()
        if gw_iface and gw_iface.startswith('vmbr'): protected.add(gw_iface)
        if not protected: protected.add("vmbr0")
        
        safe_list = [br for br in br_list if br not in protected and br.strip()]
        
        try:
            with open('/etc/network/interfaces', 'r') as f: lines = f.readlines()
        except: lines = []
        
        out = []
        skip = False
        for line in lines:
            s = line.strip()
            if s.startswith('auto ') or s.startswith('iface ') or s.startswith('allow-hotplug '):
                parts = s.split()
                if len(parts) > 1 and parts[1] in safe_list:
                    skip = True
                    continue
                else: skip = False
            
            if skip:
                if s == "" or line.startswith(' ') or line.startswith('\\t') or s.startswith('#'): continue
                else: skip = False
                
            if not skip: out.append(line)
            
        while out and out[-1].strip() == "": out.pop()
        out.append('\\n')
        
        with open('/etc/network/interfaces', 'w') as f: f.writelines(out)
        print("BR_TO_DEL::" + json.dumps(safe_list))
    except Exception as e:
        print("BR_TO_DEL::[]")
    """
    _, raw_data, _ = run_remote_python(ip, password, fetch_script)
    br_to_delete = []
    try:
        json_str = [line for line in raw_data.splitlines() if line.startswith("BR_TO_DEL::")][0].replace("BR_TO_DEL::", "")
        br_to_delete = json.loads(json_str)
    except: pass
    if br_to_delete:
        cmd = "nohup bash -c 'sleep 3; ifreload -a' >/dev/null 2>&1 &"
        run_ssh(ip, password, cmd)

