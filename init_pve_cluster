        try:
            out = subprocess.check_output(['ip', '-o', '-4', 'addr', 'show'], text=True)
            for line in out.splitlines():
                parts = line.split()
                if len(parts) >= 4: local_ips.append(parts[3].split('/')[0])
        except: pass
        remote_pve_ips = [ip for ip in pve_ips if ip not in local_ips]
        local_pve_ips = [ip for ip in pve_ips if ip in local_ips]
        ordered_pve_ips = remote_pve_ips + local_pve_ips

        for nip in ordered_pve_ips:
            print_color(YELLOW, f"Nuclear Reset ({clean_mode.upper()} MODE) on PVE {nip}... ", end='')
            nuclear_reset_node(nip, common_pass, False, clean_mode)
            print_color(GREEN, "OK")
            
        for qip in qdev_ips:
            print_color(YELLOW, f"Purging QDevice on {qip}... ", end='')
            qdev_heal = "systemctl stop corosync-qnetd 2>/dev/null || true; apt-get purge -y corosync-qnetd 2>/dev/null || true; rm -rf /etc/corosync/qnetd/* /etc/corosync/qnetd.conf 2>/dev/null || true"
            run_ssh(qip, common_pass, qdev_heal)
            print_color(GREEN, "OK")
            
        if clean_net:
            for nip in ordered_pve_ips:
                print_color(YELLOW, f"Asynchronous Network Purge queued on PVE {nip}... ", end='')
                clean_network_bridges(nip, common_pass)
                print_color(GREEN, "OK")
        print_color(GREEN, "\nCluster destroyed successfully."); sys.exit(0)
    else: print_color(YELLOW, "Security word incorrect. Aborted."); sys.exit(0)

def handle_rollback():
    print_color(YELLOW, "\n\n⚠️  Manual Interruption (Ctrl+C) detected.")
    choice = tui_menu("Do you really want to cancel and exit the script?", ["No, resume script", "Yes, cancel and exit"], orientation="horizontal")
    if choice == 1:
        if nodes:
            print_color(RED, f"Nodes have been partially configured: {[n.hostname for n in nodes]}")
            rb_choice = tui_menu("Trigger a CASCADE ROLLBACK (Cleanup) on these nodes?", ["No, leave as is", "Yes, clean them up"], orientation="horizontal")
            if rb_choice == 1:
                net_choice = tui_menu("Also delete the additional virtual bridges (vmbr) created?", ["No, keep them", "Yes, delete them"], orientation="horizontal")
                destroy = input(f"Type '{RED}DESTROY{NC}' to confirm node annihilation : ")
                if destroy == "DESTROY":
                    for node in nodes:
                        print_color(NC, f"  -> Rollback of {node.hostname} ({node.ip})... ", end='')
                        nuclear_reset_node(node.ip, node.password, (net_choice == 1), "soft")
                        print_color(GREEN, "OK")
        sys.exit(1)

