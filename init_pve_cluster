def clean_network_bridges(ip, password):
    """Intelligently and asynchronously wipes secondary bridges from a remote PVE node."""
    fetch_script = """
    import os, subprocess, json
    try:
        target_ip = PARAMS.get("target_ip", "")
        
        def get_iface(search_ip):
            if not search_ip: return ""
            try:
                out = subprocess.check_output(['ip', '-o', '-4', 'addr', 'show'], text=True)
                for line in out.splitlines():
                    parts = line.split()
                    if len(parts) >= 4 and parts[3].split('/')[0] == search_ip:
                        return parts[1]
            except: pass
            return ""

        ssh_iface = get_iface(target_ip)
        
        gw_iface = ""
        try:
            gw_out = subprocess.check_output("ip route show default | head -n 1 | awk '{print $5}'", shell=True, text=True).strip()
            gw_iface = gw_out
        except: pass
        
        br_list = [f for f in os.listdir('/sys/class/net') if f.startswith('vmbr')]
        protected = set([i for i in [ssh_iface, gw_iface] if i])
        if not protected: protected.add("vmbr0")
        
        safe_list = [br for br in br_list if br not in protected and br.strip()]
        
        try:
            with open('/etc/network/interfaces', 'r') as f: lines = f.readlines()
        except: lines = []
        
        out = []
        skip = False
        for line in lines:
            s = line.strip()
            if s.startswith('auto ') or s.startswith('iface ') or s.startswith('allow-hotplug '):
                parts = s.split()
                if len(parts) > 1 and parts[1] in safe_list:
                    skip = True
                    continue
                else: skip = False
            
            if skip:
                if s == "" or line.startswith(' ') or line.startswith('\\t') or s.startswith('#'): continue
                else: skip = False
                
            if not skip: out.append(line)
            
        while out and out[-1].strip() == "": out.pop()
        out.append('\\n')
        
        with open('/etc/network/interfaces', 'w') as f: f.writelines(out)
        
        print("BR_TO_DEL::" + json.dumps(safe_list))
    except Exception as e:
        print("BR_TO_DEL::[]")
    """
    _, raw_data, _ = run_remote_python(ip, password, fetch_script, {"target_ip": ip})
    
    br_to_delete = []
    try:
        json_str = [line for line in raw_data.splitlines() if line.startswith("BR_TO_DEL::")][0].replace("BR_TO_DEL::", "")
        br_to_delete = json.loads(json_str)
    except: pass
    
    if br_to_delete:
        cmd = "nohup bash -c 'sleep 3; ifreload -a' >/dev/null 2>&1 &"
        run_ssh(ip, password, cmd)

def nuclear_reset_node(ip, password, clean_net):
    """Resets the cluster config on a node, and optionally clears the network."""
    clean_cmd = "systemctl stop pve-cluster corosync 2>/dev/null || true; killall -9 pmxcfs 2>/dev/null || true; umount -l /etc/pve 2>/dev/null || true; rm -rf /var/lib/pve-cluster/config.db /var/lib/pve-cluster/.pve-lock /etc/corosync/* /var/lib/corosync/* /etc/pve/corosync.conf 2>/dev/null || true; sed -i '/PVE_CLUSTER/d' /etc/hosts; systemctl start pve-cluster 2>/dev/null || true; systemctl restart pvedaemon pveproxy 2>/dev/null || true; sleep 2"
    run_ssh(ip, password, clean_cmd)
    
    if clean_net:
        clean_network_bridges(ip, password)
        
    subprocess.run(['ssh-keygen', '-f', os.path.expanduser('~/.ssh/known_hosts'), '-R', ip], stderr=subprocess.DEVNULL)

