def handle_rollback():
    print_color(YELLOW, "\n\n⚠️  Manual Interruption (Ctrl+C) detected.")
    choice = tui_menu("Do you really want to cancel and exit the script?", ["No, resume script", "Yes, cancel and exit"], orientation="horizontal")
    
    if choice == 1:
        if nodes:
            print_color(RED, f"Nodes have been partially configured: {[n.hostname for n in nodes]}")
            rb_choice = tui_menu("Trigger a CASCADE ROLLBACK (Cleanup) on these nodes?", ["No, leave as is", "Yes, clean them up"], orientation="horizontal")
            if rb_choice == 1:
                net_choice = tui_menu("Also delete the additional virtual bridges (vmbr) created?", ["No, keep them", "Yes, delete them"], orientation="horizontal")
                print_color(RED, "\n!!! WARNING !!!")
                destroy = input(f"Type '{RED}DESTROY{NC}' to confirm node annihilation : ")
                if destroy == "DESTROY":
                    print_color(YELLOW, "Starting cascade rollback...")
                    for node in nodes:
                        print_color(NC, f"  -> Rollback of {node.hostname} ({node.ip})... ", end='')
                        nuclear_reset_node(node.ip, node.password, (net_choice == 1))
                        print_color(GREEN, "OK")
                else:
                    print_color(YELLOW, "Security word incorrect. Rollback aborted.")
        print_color(RED, "Script terminated.")
        sys.exit(1)
    else:
        print_color(GREEN, "Resuming script...")

# --- MAIN LOGIC ---

def main():
    global global_cidr_subnet, last_password, prev_c_ip, global_cluster_name, global_edit_mode, last_qpass
    
    if os.geteuid() != 0:
        print_color(RED, "Error: Root privileges required.")
        sys.exit(1)
        
    parser = argparse.ArgumentParser(description="Proxmox Cluster Deployment Tool")
    parser.add_argument('--clean', action='store_true', help='Destroy existing cluster')
    args = parser.parse_args()

    install_dependencies()
    
    if args.clean:
        destroy_entire_cluster(None, None)

    os.system('clear')
    print_color(GREEN, "--- PROXMOX CLUSTER INITIALIZATION v64.0.0-SCREEN-AUTOCLOSE ---\n")
    node_idx = 1
    
    while True:
        print_color(CYAN, "====================================================")
        print_color(CYAN, f"           CONFIGURATION OF PVE NODE #{node_idx}    ")
        print_color(CYAN, "====================================================")
        
        ip = input_prefill("PVE Management IP (leave empty to stop): ")
        if not ip:
            if not nodes: sys.exit(0)
            elif len(nodes) < 2 and not any(n.has_cluster for n in nodes):
                print_color(RED, "Error: A new cluster requires at least 2 nodes.")
                continue
            else: break
                
        try: ipaddress.IPv4Address(ip)
        except: print_color(RED, "Invalid IP format."); continue
            
        if subprocess.run(['ping', '-c', '1', '-W', '1', ip], stdout=subprocess.DEVNULL).returncode != 0:
            print_color(RED, "IP unreachable."); continue
            
        if any(n.ip == ip for n in nodes):
            print_color(RED, "Error: This IP has already been registered."); continue
            
        try: detected_host = subprocess.check_output(f"getent hosts {ip} | awk '{{print $2}}' | cut -d'.' -f1", shell=True, text=True).strip()
        except: detected_host = ""
            
        while True:
            host = input_prefill("Hostname for this IP: ", detected_host)
            if not host: print_color(RED, "Required."); continue
            if any(n.hostname == host for n in nodes): print_color(RED, "Error: Hostname already used."); continue
            break
            
        while True:
            prompt_str = "Root password (if empty, reuse previous password): " if last_password else "Root password: "
            current_password = getpass.getpass(prompt_str) or last_password
            code, _, _ = run_ssh(ip, current_password, "true")
            if code == 0: break
            else:
                print_color(RED, "Authentication failed.")
                last_password = ""

        # --- CLUSTER AWARENESS DETECT ---
        has_cluster = False
        code, out, _ = run_ssh(ip, current_password, "[ -f /etc/pve/corosync.conf ] && echo 1 || echo 0")
        if out.strip() == "1":
            if global_edit_mode:
                act = 0
                print_color(YELLOW, f"\n  -> Auto-managing existing node {host} (Edit mode active).")
            else:
                print()
                act = tui_menu(f"Existing cluster detected on {host}. Select action:", ["Manage existing node", "Destroy cluster (Reset node)", "Abort"], default_idx=0)
            
            if act == 1:
                destroy_entire_cluster(ip, current_password)
            elif act == 2:
                continue
            else:
                has_cluster = True
                global_edit_mode = True
                if not global_cluster_name:
                    _, cname, _ = run_ssh(ip, current_password, "grep -oP '(?<=cluster_name: ).*' /etc/pve/corosync.conf 2>/dev/null")
                    if cname.strip(): global_cluster_name = cname.strip()

        ssh_prep = "mkdir -p /root/.ssh && echo -e 'Host *\\n\\tStrictHostKeyChecking no\\n\\tUserKnownHostsFile /dev/null' > /root/.ssh/config"
        run_ssh(ip, current_password, ssh_prep)

        # --- NETWORK MANAGER LOOP ---
        while True:
            print_color(YELLOW, f"\n--- NETWORK MANAGER : {host} ---")
            remote_network_scan(ip, current_password)
            
            net_opts = [
                "Create a virtual bridge (vmbr)",
                "Modify an existing virtual bridge",
                "Delete an existing virtual bridge",
                "Validate network topology and continue"
            ]
            
            print()
            net_choice = tui_menu("Select an action:", net_opts, default_idx=3)
                
            if net_choice == 0:
                print_color(CYAN, "\n  [Create Bridge]")
                curr_bridges = fetch_bridge_list(ip, current_password)
                existing_nums = [int(re.search(r'^vmbr(\d+)$', b["name"]).group(1)) for b in curr_bridges if re.match(r'^vmbr\d+$', b["name"])]
                next_v = max(existing_nums) + 1 if existing_nums else 0
                
                new_vmbr = input_prefill("  Bridge name : ", f"vmbr{next_v}")
                br_comment = input_prefill("  Description/Comment (e.g., iSCSI Network) : ").replace('"', '')
                phys_iface = input_prefill("  Interface(s) (Space or comma) : ").replace(',', ' ').strip()
                
                print()
                br_vlan_opt = tui_menu("  VLAN aware?", ["No", "Yes"], orientation="horizontal")
                br_vlan = "Y" if br_vlan_opt == 1 else "N"
                br_vids = "2-4094"
                if br_vlan == "Y":
                    br_vids = input_prefill("  Allowed VLAN(s) (e.g., 10 or 2-4094) : ", "2-4094")
                    
                br_mtu = input_prefill("  MTU (empty = 1500) : ")
                
                while True:
                    new_cidr = input_prefill("  IP/CIDR (e.g., 10.10.10.11/24, empty = manual) : ")
                    if not new_cidr: break
                    try:
                        chk_ip = new_cidr.split('/')[0]
                        ipaddress.IPv4Address(chk_ip)
                        code, out, _ = run_ssh(ip, current_password, f"ip -o -4 addr show | grep -q ' {chk_ip}/' && echo 1 || echo 0")
                        if out.strip() == "1":
                            print_color(RED, "IP already in use."); continue
                        break
                    except: print_color(RED, "Invalid format.")
                
                print_color(NC, "  -> Deploying GUI compliant configuration... ", end='')
                params = {"action": "create", "iface": new_vmbr, "comment": br_comment, "address": new_cidr, "gateway": "", "ports": phys_iface, "vlan_aware": br_vlan, "vids": br_vids, "mtu": br_mtu}
                run_remote_python(ip, current_password, REMOTE_NET_WRITER, params)
                run_ssh(ip, current_password, "ifreload -a > /dev/null 2>&1")
                print_color(GREEN, "Done.")

            elif net_choice == 1:
                print_color(CYAN, "\n  [Modify Bridge]")
                bridges = fetch_bridge_list(ip, current_password)
                if not bridges:
                    print_color(YELLOW, "  No bridges found to modify."); continue
                
                opts = [b["display"] for b in bridges] + ["Cancel"]
                print()
                br_idx = tui_menu("  Select a bridge to modify:", opts)
                if br_idx == len(bridges): continue
                
                if bridges[br_idx].get("locked"):
                    print_color(RED, f"  Action blocked: {bridges[br_idx]['name']} is locked by Corosync (Cluster Network).")
                    continue
                
                mod_vmbr = bridges[br_idx]["name"]
                fetch_script = f"""
                import subprocess, json, socket
                try:
                    node = socket.gethostname()
                    out = subprocess.check_output(['pvesh', 'get', f'/nodes/{{node}}/network/{mod_vmbr}', '--output-format', 'json'])
                    d = json.loads(out)
                    comment = d.get('comments', '')
                    if not comment:
                        try:
                            c_out = subprocess.check_output(f"grep -A 10 '^auto {mod_vmbr}' /etc/network/interfaces | grep '^#' | head -n 1", shell=True, text=True)
                            comment = c_out.strip().lstrip('#').strip()
                        except: pass
                    comment = str(comment).replace('\\n', ' ').replace('\\r', '').strip()
                    res = {{
                        "comment": comment,
                        "cidr": f"{{d.get('address', '')}}/{{d.get('netmask', '')}}" if d.get('address') else "",
                        "ports": d.get('bridge_ports', ''),
                        "vlan": 'Y' if d.get('bridge_vlan_aware') else 'N',
                        "mtu": d.get('mtu', ''),
                        "vids": d.get('bridge_vids', '2-4094'),
                        "gw": d.get('gateway', '')
                    }}
                    print("PVE_DATA::" + json.dumps(res))
                except: print("PVE_DATA::{{}}")
                """
                _, raw_data, _ = run_remote_python(ip, current_password, fetch_script)
                try:
                    json_str = [line for line in raw_data.split('\n') if line.startswith("PVE_DATA::")][0].replace("PVE_DATA::", "")
                    d = json.loads(json_str)
                except: d = {}

                new_comment = input_prefill("  Description/Comment : ", d.get('comment', '')).replace('"', '')
                new_ports = input_prefill("  Interface(s) : ", d.get('ports', '')).replace(',', ' ').strip()
                
                print()
                def_vlan_idx = 1 if d.get('vlan') == 'Y' else 0
                new_vlan_opt = tui_menu("  VLAN aware?", ["No", "Yes"], orientation="horizontal", default_idx=def_vlan_idx)
                new_vlan = "Y" if new_vlan_opt == 1 else "N"
                
                new_vids = d.get('vids', '2-4094')
                if new_vlan == "Y":
                    new_vids = input_prefill("  Allowed VLAN(s) : ", new_vids)
                    
                new_mtu = input_prefill("  MTU (empty = 1500) : ", str(d.get('mtu', '')))
                new_cidr = input_prefill("  IP/CIDR (empty = manual) : ", d.get('cidr', ''))
                
                new_gw = d.get('gw', '')
                if new_gw:
                    new_gw = input_prefill("  Gateway : ", new_gw)
                    
                print_color(NC, "  -> Perfect atomic file update... ", end='')
                params = {"action": "modify", "iface": mod_vmbr, "comment": new_comment, "address": new_cidr, "gateway": new_gw, "ports": new_ports, "vlan_aware": new_vlan, "vids": new_vids, "mtu": new_mtu}
                run_remote_python(ip, current_password, REMOTE_NET_WRITER, params)
                run_ssh(ip, current_password, "ifreload -a > /dev/null 2>&1")
                print_color(GREEN, "Done.")

            elif net_choice == 2:
                print_color(CYAN, "\n  [Delete Bridge]")
                bridges = fetch_bridge_list(ip, current_password)
                if not bridges:
                    print_color(YELLOW, "  No bridges found to delete."); continue
                
                opts = [b["display"] for b in bridges] + ["Cancel"]
                print()
                br_idx = tui_menu("  Select a bridge to delete:", opts)
                if br_idx == len(bridges): continue
                
                if bridges[br_idx].get("locked"):
                    print_color(RED, f"  Action blocked: {bridges[br_idx]['name']} is locked by Corosync (Cluster Network).")
                    continue
                
                mod_vmbr = bridges[br_idx]["name"]
                _, mgt_iface_raw, _ = run_ssh(ip, current_password, f"ip -o -4 addr show | grep -w '{ip}' | awk '{{print $2}}' | head -n 1")
                mgt_iface = mgt_iface_raw.strip()
                if mod_vmbr == mgt_iface:
                    print_color(RED, f"Action blocked: {mod_vmbr} carries the active management IP ({ip}). Deleting it would sever the connection.")
                else:
                    print_color(NC, f"  -> Destroying {mod_vmbr}... ", end='')
                    params = {"action": "delete", "iface": mod_vmbr}
                    run_remote_python(ip, current_password, REMOTE_NET_WRITER, params)
                    run_ssh(ip, current_password, "ifreload -a > /dev/null 2>&1")
                    print_color(GREEN, "Done.")

            elif net_choice == 3:
                break

        print_color(YELLOW, f"\n  Corosync Role Assignment for {host}")
        ip_list = fetch_ip_list(ip, current_password)
        if not ip_list:
            print_color(RED, "Fatal: No IPs found on the server.")
            sys.exit(1)

        c_ip = ""
        if has_cluster:
            print_color(GREEN, "  -> Cluster detected. Auto-mapping Corosync IP from config...")
            try:
                _, conf_out, _ = run_ssh(ip, current_password, "cat /etc/pve/corosync.conf 2>/dev/null || echo ''")
                c_ips = set(re.findall(r'ring\d_addr:\s*([^\s]+)', conf_out))
                for item in ip_list:
                    check_ip = item["ip"].split('/')[0]
                    if check_ip in c_ips:
                        c_ip = check_ip
                        break
            except Exception: pass
            
            if not c_ip:
                c_ip = ip
                print_color(YELLOW, f"  -> Could not parse config, falling back to management IP: {c_ip}")
            else:
                print_color(CYAN, f"  -> Active Corosync IP locked to: {c_ip}")

            if not global_cidr_subnet:
                matched_cidr = next((i["ip"] for i in ip_list if i["ip"].startswith(f"{c_ip}/")), None)
                if matched_cidr:
                    global_cidr_subnet = str(ipaddress.ip_interface(matched_cidr).network)
                else:
                    global_cidr_subnet = str(ipaddress.ip_interface(f"{c_ip}/24").network)
        else:
            opts = [i["display"] for i in ip_list] + ["Manual Entry"]
            def_idx = 0
            
            if not global_cidr_subnet:
                print()
                c_idx = tui_menu("Select Corosync IP:", opts)
                if c_idx == len(ip_list):
                    c_input = input_prefill("  Enter Corosync IP : ", ip)
                    c_ip = c_input.split('/')[0]
                    matched_cidr = next((i["ip"] for i in ip_list if i["ip"].startswith(f"{c_ip}/")), None)
                    if not matched_cidr:
                        print_color(RED, "IP not assigned locally. Assuming /24 subnet.")
                        global_cidr_subnet = str(ipaddress.ip_interface(f"{c_ip}/24").network)
                    else: global_cidr_subnet = str(ipaddress.ip_interface(matched_cidr).network)
                else:
                    c_ip = ip_list[c_idx]["ip"].split('/')[0]
                    global_cidr_subnet = str(ipaddress.ip_interface(ip_list[c_idx]["ip"]).network)
            else:
                for i, item in enumerate(ip_list):
                    try:
                        if ipaddress.ip_interface(item["ip"]).network == ipaddress.ip_network(global_cidr_subnet):
                            def_idx = i
                            break
                    except: pass
                    
                suggested_ip = str(ipaddress.IPv4Address(prev_c_ip) + 1) if prev_c_ip else ""
                print(f"  Expected cluster network: {global_cidr_subnet}")
                
                print()
                c_idx = tui_menu("Select Corosync IP:", opts, default_idx=def_idx)
                if c_idx == len(ip_list):
                    c_input = input_prefill("  Enter Corosync IP : ", suggested_ip)
                    c_ip = c_input.split('/')[0]
                else:
                    c_ip = ip_list[c_idx]["ip"].split('/')[0]

        prev_c_ip = c_ip
        nodes.append(Node(ip, host, current_password, c_ip, has_cluster))
        last_password = current_password
        node_idx += 1

    # --- CLUSTER DEFINITION ---
    print_color(CYAN, "\n====================================================")
    if not global_cluster_name:
        while True:
            cluster_name = input_prefill("Cluster Name (e.g., datacenter1) : ")
            if not cluster_name: print_color(RED, "Required.")
            elif not cluster_name.replace('_', '').replace('-', '').isalnum(): print_color(RED, "Alphanumeric only.")
            else: 
                global_cluster_name = cluster_name
                break
    else:
        print(f"Using Existing Cluster Name: {global_cluster_name}")

    first_node = nodes[0]

    # --- 3. FULL MESH PING TEST ---
    print_color(YELLOW, "\n[1/7] Corosync Full-Mesh Connectivity Test...")
    all_ok = True
    for i, source in enumerate(nodes):
        for j, target in enumerate(nodes):
            if i != j:
                print_color(NC, f"  -> Ping: {source.hostname} -> {target.corosync_ip} ... ", end='')
                code, _, _ = run_ssh(source.ip, source.password, f"ping -c 1 -W 2 {target.corosync_ip}")
                if code == 0: print_color(GREEN, "OK")
                else: print_color(RED, "FAILED"); all_ok = False
                    
    if not all_ok:
        print_color(RED, "Network not routable. (Ctrl+C for Rollback)")
        sys.exit(1)

    # --- 4. REPOS & HOSTS ---
    print_color(YELLOW, "\n[2/7] Repositories and dependencies...")
    repo_script = """
    export DEBIAN_FRONTEND=noninteractive
    rm -f /etc/apt/sources.list.d/pve-enterprise.* /etc/apt/sources.list.d/ceph.* 2>/dev/null || true
    sed -i '/enterprise.proxmox.com/d' /etc/apt/sources.list /etc/apt/sources.list.d/* 2>/dev/null || true
    CODENAME=$(grep "VERSION_CODENAME=" /etc/os-release | cut -d'=' -f2 || echo "trixie")
    echo "deb http://download.proxmox.com/debian/pve $CODENAME pve-no-subscription" > /etc/apt/sources.list.d/pve-no-subscription.list
    apt-get update -qq > /dev/null
    apt-get install -yq expect jq multipath-tools > /dev/null
    """
    
    for node in nodes:
        print_color(NC, f"  -> Configuring {node.hostname}... ", end='')
        run_ssh(node.ip, node.password, "systemctl start pve-cluster 2>/dev/null || true")
        run_ssh(node.ip, node.password, repo_script)
        for target in nodes: run_ssh(node.ip, node.password, f"sed -i '/{target.ip}/d' /etc/hosts")
        hosts_injection = "\n".join([f"echo '{n.ip} {n.hostname} # PVE_CLUSTER' >> /etc/hosts" for n in nodes])
        run_ssh(node.ip, node.password, hosts_injection)
        print_color(GREEN, "OK")

    # --- 5. CREATE CLUSTER ---
    if not first_node.has_cluster:
        print_color(YELLOW, f"\n[3/7] Creating cluster '{global_cluster_name}'... ", end='')
        run_ssh(first_node.ip, first_node.password, f"pvecm create {global_cluster_name} --link0 {first_node.corosync_ip}")
        print_color(GREEN, "OK")
    else:
        print_color(YELLOW, f"\n[3/7] Cluster '{global_cluster_name}' already exists on {first_node.hostname}. Skipping creation.")

    # --- 6. JOIN NODES ---
    print_color(YELLOW, "\n[4/7] Joining nodes to cluster...")
    for node in nodes[1:]:
        if node.has_cluster:
            _, out, _ = run_ssh(node.ip, node.password, "grep -oP '(?<=cluster_name: ).*' /etc/pve/corosync.conf 2>/dev/null")
            if out.strip() == global_cluster_name:
                print_color(GREEN, f"  -> {node.hostname} is already a member of '{global_cluster_name}'. Skipping.")
                continue
            else:
                print_color(RED, f"  -> {node.hostname} is in a DIFFERENT cluster ({out.strip()}). Cannot join.")
                sys.exit(1)

        print_color(NC, f"  -> Integrating {node.hostname}... ", end='')
        reset_cmd = "systemctl stop pve-cluster corosync 2>/dev/null || true; killall -9 pmxcfs 2>/dev/null || true; umount -l /etc/pve 2>/dev/null || true; rm -rf /var/lib/pve-cluster/config.db /var/lib/pve-cluster/.pve-lock 2>/dev/null || true; rm -rf /etc/corosync/* /var/lib/corosync/* /etc/pve/corosync.conf 2>/dev/null || true; systemctl start pve-cluster; sleep 3"
        run_ssh(node.ip, node.password, reset_cmd)
        
        safe_master_pass = first_node.password.replace("'", "'\\''")
        expect_script = textwrap.dedent(f"""
        set timeout 120
        set master_pass $env(MASTER_PASS)
        spawn pvecm add {first_node.ip} -link0 {node.corosync_ip}
        expect {{
            -re ".*(yes/no).*\\\\?" {{ send "yes\\r"; exp_continue }}
            -re "(?i)password.*:" {{ send "$master_pass\\r"; exp_continue }}
            eof
        }}
        catch wait result
        exit [lindex $result 3]
        """)
        
        b64_expect = base64.b64encode(expect_script.encode()).decode()
        join_cmd = f"export MASTER_PASS='{safe_master_pass}'; echo '{b64_expect}' | base64 -d | expect > /dev/null 2>&1"
        
        code, out, err = run_ssh(node.ip, node.password, join_cmd)
        
        if code == 0: print_color(GREEN, "Success")
        else:
            print_color(RED, "FAILED")
            print_color(YELLOW, "--- Error Logs ---")
            print(out)
            print(err)
            sys.exit(1)

    # --- 7. QDEVICE AUTO-HEAL ---
    print_color(YELLOW, "\n[5/7] QDevice Configuration...")
    _, pvecm_out, _ = run_ssh(first_node.ip, first_node.password, "pvecm status")
    
    try: cluster_nodes = int(re.search(r'Nodes:\s+(\d+)', pvecm_out).group(1))
    except: cluster_nodes = len(nodes)
    
    has_qdevice = "Qdevice information" in pvecm_out or "Qdevice" in pvecm_out
    
    if cluster_nodes < 3:
        if has_qdevice:
            print_color(GREEN, "  -> QDevice already active for 2-node cluster. Skipping.")
        else:
            print()
            add_qdev = tui_menu("Configure a QDevice Witness (<3 nodes)?", ["No", "Yes"], orientation="horizontal")
            if add_qdev == 1:
                while True:
                    qip = input_prefill("  QDevice IP (Empty to skip) : ")
                    if not qip:
                        break
                        
                    fallback_qpass = last_qpass if last_qpass else last_password
                    prompt_str = "  QDevice Root Password (if empty, reuse cluster password): " if fallback_qpass else "  QDevice Root Password : "
                    qpass = getpass.getpass(prompt_str)
                    if not qpass:
                        if fallback_qpass:
                            qpass = fallback_qpass
                        else:
                            print_color(RED, "  Password required.")
                            continue
                            
                    print_color(NC, "  -> Probing QDevice server... ", end='')
                    
                    probe_cmd = "echo \"QDEV_PROBE::$(hostname)::$([ -d /etc/corosync/qnetd ] && echo 1 || echo 0)\""
                    code, out, _ = run_ssh(qip, qpass, probe_cmd)
                    
                    if code != 0:
                        print_color(RED, "Connection failed or invalid credentials.")
                        continue
                        
                    try:
                        probe_res = [line for line in out.splitlines() if line.startswith("QDEV_PROBE::")][0]
                        _, q_hostname, q_state = probe_res.split("::")
                        print_color(GREEN, "Connected.")
                    except:
                        print_color(RED, "Failed to parse target server information.")
                        continue
                        
                    print()
                    print_color(CYAN, f"  Target QDevice identified as : \033[1;32m{q_hostname}\033[0;36m ({qip})")
                    conf_qdev = tui_menu(f"Proceed with configuring {q_hostname} as QDevice?", ["No, select another IP", "Yes, configure this server"], orientation="horizontal", default_idx=1)
                    if conf_qdev == 0:
                        continue
                        
                    if q_state == "1":
                        print_color(YELLOW, f"\n  ⚠️  Existing QDevice configuration detected on {q_hostname}.")
                        print()
                        purge_choice = tui_menu(f"Purge and reset {q_hostname}?", ["No, select another IP", "Yes, purge and reinstall"], orientation="horizontal", default_idx=1)
                        if purge_choice == 0:
                            continue
                            
                    last_qpass = qpass
                    
                    print_color(NC, "  -> Preparing nodes... ", end='')
                    for node in nodes:
                        run_ssh(node.ip, node.password, "export DEBIAN_FRONTEND=noninteractive; apt-get install -yq corosync-qdevice > /dev/null")
                    print_color(GREEN, "OK")
                    
                    print_color(NC, "  -> Auto-Healing target QDevice server... ", end='')
                    qdev_heal = """
                    systemctl stop corosync-qnetd 2>/dev/null || true
                    if command -v apt-get >/dev/null 2>&1; then
                        export DEBIAN_FRONTEND=noninteractive
                        apt-get purge -y corosync-qnetd 2>/dev/null || true
                        rm -rf /etc/corosync/qnetd/* /etc/corosync/qnetd.conf 2>/dev/null || true
                        apt-get update -qq > /dev/null
                        apt-get install -yq corosync-qnetd > /dev/null
                    elif command -v dnf >/dev/null 2>&1; then
                        dnf remove -y corosync-qnetd 2>/dev/null || true
                        rm -rf /etc/corosync/qnetd/* /etc/corosync/qnetd.conf 2>/dev/null || true
                        dnf install -y corosync-qnetd > /dev/null
                    elif command -v yum >/dev/null 2>&1; then
                        yum remove -y corosync-qnetd 2>/dev/null || true
                        rm -rf /etc/corosync/qnetd/* /etc/corosync/qnetd.conf 2>/dev/null || true
                        yum install -y corosync-qnetd > /dev/null
                    else
                        echo "UNSUPPORTED_OS"
                        exit 1
                    fi
                    systemctl enable --now corosync-qnetd > /dev/null 2>&1 || true
                    """
                    run_ssh(qip, qpass, qdev_heal)
                    
                    run_ssh(first_node.ip, first_node.password, "pvecm qdevice remove 2>/dev/null || true; rm -rf /etc/corosync/qdevice/net/nssdb/* 2>/dev/null || true")
                    print_color(GREEN, "OK")
                    
                    print_color(NC, "  -> Registering QDevice... ", end='')
                    expect_qdev = textwrap.dedent(f"""
                    set timeout 120
                    set qpass $env(QPASS)
                    spawn pvecm qdevice setup {qip} -force
                    expect {{
                        -re ".*(yes/no).*\\\\?" {{ send "yes\\r"; exp_continue }}
                        -re "(?i)password.*:" {{ send "$qpass\\r"; exp_continue }}
                        eof
                    }}
                    catch wait result
                    exit [lindex $result 3]
                    """)
                    
                    run_ssh(first_node.ip, first_node.password, f"ssh-keyscan -H {qip} >> /root/.ssh/known_hosts 2>/dev/null")
                    safe_qpass = qpass.replace("'", "'\\''")
                    b64_qdev = base64.b64encode(expect_qdev.encode()).decode()
                    qdev_cmd = f"export QPASS='{safe_qpass}'; echo '{b64_qdev}' | base64 -d | expect > /dev/null"
                    
                    code, out, err = run_ssh(first_node.ip, first_node.password, qdev_cmd)
                    
                    _, check_out, _ = run_ssh(first_node.ip, first_node.password, "pvecm status")
                    if code == 0 and "Qdevice" in check_out:
                        print_color(GREEN, "Success")
                    else:
                        print_color(RED, "FAILED")
                        print_color(YELLOW, "--- Error Logs ---")
                        print(out)
                        print(err)
                    break
    else:
        print(f"  Not required ({cluster_nodes} nodes detected in cluster).")

    # --- 8. DATACENTER OPTIONS ---
    print_color(YELLOW, "\n[6/7] Global Datacenter Options...")
    _, current_mig, _ = run_ssh(first_node.ip, first_node.password, "grep -oP '(?<=^migration: ).*' /etc/pve/datacenter.cfg 2>/dev/null || echo 'Default'")
    
    mig_options = ["Keep current"]
    if global_cidr_subnet: mig_options.append(f"Dedicated Corosync Network ({global_cidr_subnet})")
    mig_options.append("Manual Entry (CIDR)")
    
    print()
    mig_choice_idx = tui_menu(f"Migration Network [Current: {current_mig.strip()}] :", mig_options)
    
    if mig_options[mig_choice_idx].startswith("Dedicated"):
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -migration type=secure,network={global_cidr_subnet}")
    elif mig_options[mig_choice_idx].startswith("Manual"):
        custom_mig = input_prefill("    CIDR : ")
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -migration type=secure,network={custom_mig}")

    _, current_ha, _ = run_ssh(first_node.ip, first_node.password, "grep -oP '(?<=^ha: ).*' /etc/pve/datacenter.cfg 2>/dev/null || echo 'Default (conditional)'")
    ha_opts = [
        "Keep current configuration",
        "conditional (Migrate if available, else freeze)",
        "migrate     (Force migration on shutdown)",
        "freeze      (Leave VMs/CTs in place)",
        "failover    (Hard stop and restart elsewhere)"
    ]
    
    print()
    ha_choice = tui_menu(f"HA Strategy [Current: {current_ha.strip()}] :", ha_opts)
    
    if ha_choice != 0:
        policies = ["", "conditional", "migrate", "freeze", "failover"]
        sel_policy = policies[ha_choice]
        run_ssh(first_node.ip, first_node.password, f"pvesh set /cluster/options -ha shutdown_policy={sel_policy}")
        print_color(GREEN, f"    -> Applied: {sel_policy}")

    # --- 9. SYSTEM UPDATES ---
    print_color(YELLOW, "\n[7/7] Asynchronous System Updates (screen)...")
    print()
    do_update = tui_menu("Launch dist-upgrade across all nodes?", ["No, skip", "Yes, start updates"], orientation="horizontal")
    if do_update == 1:
        for node in nodes:
            run_ssh(node.ip, node.password, "export DEBIAN_FRONTEND=noninteractive; apt-get update -qq > /dev/null && apt-get install -yq screen > /dev/null")
            update_cmd = f"export DEBIAN_FRONTEND=noninteractive; echo '--- UPGRADE START ---' > /root/update_{node.hostname}.log; apt-get dist-upgrade -y >> /root/update_{node.hostname}.log 2>&1; echo '--- FINISHED ---' >> /root/update_{node.hostname}.log"
            run_ssh(node.ip, node.password, f"screen -dmS upg_{node.hostname} bash -c \"{update_cmd}\"")
        print_color(CYAN, "  Tracking: login to nodes and type 'screen -r' (sessions will auto-close when done)")

    print_color(GREEN, "\nCLUSTER INITIALIZATION COMPLETED SUCCESSFULLY!")
    _, status, _ = run_ssh(first_node.ip, first_node.password, "pvecm status")
    for line in status.split('\n'):
        if any(kw in line for kw in ["Quorum", "Nodes", "Name", "Node IP"]):
            print(line)

