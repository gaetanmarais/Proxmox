def print_color(color, text, end='\n'):
    print(f"{color}{text}{NC}", end=end, flush=True)

def input_prefill(prompt, default_text=""):
    """Replicates Bash 'read -e -i' allowing arrow-key editing."""
    def hook():
        readline.insert_text(str(default_text))
        readline.redisplay()
    readline.set_pre_input_hook(hook)
    try:
        result = input(prompt)
    finally:
        readline.set_pre_input_hook()
    return result.strip()

def tui_menu(title, options, orientation="vertical", default_idx=0):
    """Flawless TUI Menu Engine with absolute mathematical cursor tracking."""
    def getch():
        fd = sys.stdin.fileno()
        old_settings = termios.tcgetattr(fd)
        try:
            tty.setraw(sys.stdin.fileno())
            ch = sys.stdin.read(1)
            if ch == '\x1b':
                ch += sys.stdin.read(2)
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
        return ch

    # Strict sanitization
    flat_options = [str(opt).replace('\n', ' ').replace('\r', '').strip() for opt in options]
    selected = default_idx
    sys.stdout.write("\033[?25l")  # Hide cursor
    
    # Exact newline tracking
    lines_down = 1 if orientation == "horizontal" else len(flat_options)
    
    # Pre-allocate layout space to prevent bottom-screen pushing
    sys.stdout.write("\n" * lines_down)
    sys.stdout.write(f"\033[{lines_down}A")
    sys.stdout.flush()
    
    try:
        while True:
            # Draw Title (Takes exactly 1 newline)
            sys.stdout.write(f"\r\033[K\033[1;36m{title}\033[0m\n")
            
            # Draw Options (Takes 0 newlines horizontally, N-1 newlines vertically)
            if orientation == "horizontal":
                line = "  "
                for i, opt in enumerate(flat_options):
                    if i == selected: line += f"\033[1;32m> {opt} <\033[0m   "
                    else: line += f"  {opt}     "
                sys.stdout.write(f"\r\033[K{line}")
            else:
                for i, opt in enumerate(flat_options):
                    prefix = "\033[1;32m>\033[0m" if i == selected else " "
                    color = "\033[1;32m" if i == selected else ""
                    reset = "\033[0m" if i == selected else ""
                    end_char = "\n" if i < len(flat_options) - 1 else ""
                    sys.stdout.write(f"\r\033[K  {prefix} {color}{opt}{reset}{end_char}")
                    
            sys.stdout.flush()
            ch = getch()
            
            if orientation == "horizontal":
                if ch == '\x1b[D': selected = (selected - 1) % len(flat_options)
                elif ch == '\x1b[C': selected = (selected + 1) % len(flat_options)
            else:
                if ch == '\x1b[A': selected = (selected - 1) % len(flat_options)
                elif ch == '\x1b[B': selected = (selected + 1) % len(flat_options)
                
            if ch in ('\r', '\n'):
                # Clear menu and show final static choice
                sys.stdout.write(f"\r\033[{lines_down}A\033[J")
                if orientation == "horizontal":
                    sys.stdout.write(f"\r\033[K\033[1;36m{title}\033[0m  \033[1;32m> {flat_options[selected]}\033[0m\n")
                else:
                    sys.stdout.write(f"\r\033[K\033[1;36m{title}\033[0m\n  \033[1;32m> {flat_options[selected]}\033[0m\n")
                return selected
            elif ch == '\x03':
                raise KeyboardInterrupt
            
            # Reset cursor absolutely
            sys.stdout.write(f"\r\033[{lines_down}A")
            
    finally:
        sys.stdout.write("\033[?25h")
        sys.stdout.flush()

def run_ssh(ip, password, cmd, stdin_str=None):
    env = os.environ.copy()
    env['SSHPASS'] = password
    args = ['sshpass', '-e', 'ssh', '-o', 'ConnectTimeout=5', '-o', 'StrictHostKeyChecking=no', f'root@{ip}']
    if isinstance(cmd, list): args.extend(cmd)
    else: args.append(cmd)
    res = subprocess.run(args, env=env, input=stdin_str, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
    return res.returncode, res.stdout, res.stderr

def run_remote_python(ip, password, script, params=None):
    header = f"PARAMS = {json.dumps(params)}\n" if params is not None else "PARAMS = {}\n"
    full_script = header + textwrap.dedent(script)
    return run_ssh(ip, password, "python3 -", stdin_str=full_script)

