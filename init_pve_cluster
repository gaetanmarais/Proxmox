def fetch_hardware_info(ip, password):
    script = """
    import json, subprocess, re, socket, os
    def run(cmd):
        try: return subprocess.check_output(cmd, shell=True, text=True).strip()
        except: return ""

    # --- CPU ---
    cpu_raw = run("lscpu")
    cpu_match = re.search(r"Model name:\\s+(.*)", cpu_raw)
    cpu_model = cpu_match.group(1) if cpu_match else "Unknown CPU"
    
    cpu_freq_match = re.search(r"@\\s*([0-9.]+)\\s*GHz", cpu_model)
    base_ghz = 0.0
    if cpu_freq_match:
        base_ghz = float(cpu_freq_match.group(1))
    else:
        try:
            mhz_str = run("lscpu | grep 'CPU max MHz:' | awk '{print $4}'").replace(',','.')
            if mhz_str: base_ghz = float(mhz_str) / 1000.0
        except: pass
        
    sockets = run("lscpu | grep 'Socket(s):' | awk '{print $2}'")
    cores = run("lscpu | grep 'Core(s) per socket:' | awk '{print $4}'")
    threads = run("lscpu | grep 'Thread(s) per core:' | awk '{print $4}'")
    ht = "Yes" if threads != "1" else "No"
    
    # --- RAM ---
    ram = run("free -h | awk '/^Mem:/ {print $2}'")
    dimm_info = ram
    try:
        dimms_raw = run("dmidecode -t 17 2>/dev/null | grep 'Size:' | grep -v 'No Module Installed'")
        dimms_list = [d.split(':')[1].strip() for d in dimms_raw.splitlines() if 'Size:' in d]
        if dimms_list:
            counts = {}
            for d in dimms_list: counts[d] = counts.get(d, 0) + 1
            dimm_info = ", ".join([f"{c}x {s}" for s, c in counts.items()]) + f" ({ram})"
    except: pass
    
    # --- GPUS & DISKS ---
    gpus = len([line for line in run("lspci").splitlines() if 'VGA' in line or '3D controller' in line])
    
    os_disk = ""
    # 1. Advanced OS Disk detection (LVM & Standard)
    try:
        tree_raw = run("lsblk -o NAME,TYPE,MOUNTPOINT,PKNAME -J 2>/dev/null")
        if tree_raw:
            def find_os(devices):
                for d in devices:
                    if d.get("mountpoint") == "/": return True
                    if find_os(d.get("children", [])): return True
                return False
            tree = json.loads(tree_raw).get("blockdevices", [])
            for d in tree:
                if find_os([d]):
                    os_disk = d.get("name")
                    break
    except: pass

    # 2. ZFS Fallback for OS Disk
    if not os_disk:
        try:
            root_src = run("findmnt -n -o SOURCE /")
            if "/" in root_src:
                pool = root_src.split("/")[0]
                z_disks = run(f"zpool status {pool} | awk '/ONLINE/ {{print $1}}'")
                for zd in z_disks.splitlines():
                    zd = zd.strip()
                    if zd.startswith(('sd', 'nvme', 'vd')):
                        os_disk = re.sub(r'p?\\d+$', '', zd) # Remove partition endings
                        break
        except: pass

    disks = []
    try:
        d_raw = json.loads(run("lsblk -d -o NAME,TYPE,SIZE,ROTA,MODEL,TRAN -J 2>/dev/null"))
        for d in d_raw.get('blockdevices', []):
            name = str(d.get('name', ''))
            tran = str(d.get('tran', '')).lower()
            # Relaxed filter for NVMe drives which might lack standard "disk" type mapping
            if (d.get('type') == 'disk' or name.startswith('nvme')) and not name.startswith(('loop', 'ram', 'sr', 'fd', 'dm-', 'rbd')):
                if tran not in ['iscsi', 'fc', 'fibrechannel']:
                    dtype = "HDD" if str(d.get('rota')) == "1" or str(d.get('rota')).lower() == "true" else "SSD/NVMe"
                    disks.append({
                        "name": "/dev/" + name,
                        "size": d.get('size', '0B'),
                        "is_flash": dtype == "SSD/NVMe",
                        "model": str(d.get('model') or '').strip(),
                        "is_os": (name == os_disk)
                    })
    except: pass

    # --- NETWORKS ---
    bridges = []
    bridged_ports = set()
    node = socket.gethostname()
    
    try:
        net_raw = json.loads(run(f"pvesh get /nodes/{node}/network --output-format json 2>/dev/null"))
        for iface in net_raw:
            itype = iface.get("type", "")
            name = iface.get("iface", "")
            if itype == "bridge":
                ip = iface.get("address", "")
                mask = str(iface.get("netmask", ""))
                cidr_str = ""
                if ip:
                    if '.' in mask:
                        try: cidr_str = str(sum([bin(int(x)).count('1') for x in mask.split('.')]))
                        except: cidr_str = "24"
                    else:
                        cidr_str = mask
                
                ports = iface.get("bridge_ports", "")
                for p in ports.replace(',', ' ').split():
                    bridged_ports.add(p.strip())
                    
                bond_slaves = ""
                if ports.startswith("bond"):
                    try:
                        with open(f'/sys/class/net/{ports}/bonding/slaves', 'r') as f:
                            bond_slaves = f.read().strip().replace(' ', ', ')
                    except: pass

                bridges.append({
                    "name": name,
                    "ip": f"{ip}/{cidr_str}" if ip else "",
                    "ports": ports,
                    "bond_slaves": bond_slaves,
                    "comment": iface.get("comments", "").replace('\\n', ' ').strip()
                })
    except: pass

    bridges = sorted(bridges, key=lambda k: k['name'])
    
    nic_summary = ""
    speed_dict = {}
    try:
        for iface in os.listdir('/sys/class/net'):
            if iface == 'lo' or iface.startswith(('vmbr', 'tap', 'veth', 'fw', 'bond')): continue
            is_down = False
            try:
                with open(f'/sys/class/net/{iface}/carrier', 'r') as f:
                    if f.read().strip() == '0': is_down = True
            except: is_down = True
            
            s = 0
            try:
                with open(f'/sys/class/net/{iface}/speed', 'r') as f:
                    s = int(f.read().strip())
            except: pass
            
            s_str = f"{s//1000}G" if s >= 1000 else (f"{s}M" if s > 0 else "Unknown")
            
            sort_key = (1 if is_down else 0, -s)
            if sort_key not in speed_dict: speed_dict[sort_key] = {"str": s_str, "total": 0, "down": 0}
            speed_dict[sort_key]["total"] += 1
            if is_down: speed_dict[sort_key]["down"] += 1
            
        summary_parts = []
        for k in sorted(speed_dict.keys()):
            data = speed_dict[k]
            down_str = f" ({data['down']} down)" if data['down'] > 0 else ""
            summary_parts.append(f"{data['total']}x {data['str']}{down_str}")
            
        nic_summary = ", ".join(summary_parts) if summary_parts else "0 Interfaces"
    except: nic_summary = "Error reading NICs"

    data = {
        "cpu": cpu_model.split(' @')[0].strip()[:45],
        "base_ghz": base_ghz,
        "sockets": sockets or "1",
        "cores": cores or "1",
        "ht": ht,
        "ram": ram or "N/A",
        "dimms": dimm_info,
        "gpus": gpus,
        "disks": disks,
        "bridges": bridges,
        "nic_summary": nic_summary
    }
    print("HW_DATA::" + json.dumps(data))
    """
    _, raw_data, _ = run_remote_python(ip, password, script)
    try:
        json_str = [line for line in raw_data.split('\n') if line.startswith("HW_DATA::")][0].replace("HW_DATA::", "")
        return json.loads(json_str)
    except: return {}

def generate_cluster_svg(cluster_name, n_list, qdev_ip, corosync_subnet, qdev_hostname="QDEVICE"):
    def escape_xml(s):
        return str(s).replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;").replace('"', "&quot;")

    p_url = "https://upload.wikimedia.org/wikipedia/commons/thumb/9/92/Logo_Proxmox.svg/1920px-Logo_Proxmox.svg.png"
    d_url = "https://www.datacore.com/wp-content/uploads/2020/02/DataCore-Logo.png"

    subnets = {}
    colors = ["#27ae60", "#e74c3c", "#3498db", "#f39c12", "#9b59b6", "#16a085"]
    c_idx = 0
    
    if corosync_subnet:
        subnets[corosync_subnet] = {"color": colors[c_idx], "y": 0, "labels": {"Corosync Cluster Network"}}
        c_idx += 1

    for n in n_list:
        for br in n.hw_data.get('bridges', []):
            ip_str = br.get('ip', '')
            if ip_str and '/' in ip_str:
                try:
                    net = str(ipaddress.IPv4Interface(ip_str).network)
                    if net not in subnets:
                        subnets[net] = {"color": colors[c_idx % len(colors)], "y": 0, "labels": set()}
                        c_idx += 1
                    
                    br_label = br['name']
                    if br.get('comment'):
                        br_label += f" ({br['comment']})"
                    subnets[net]["labels"].add(br_label)
                except: pass

    qdev_target_net = None
    qdev_target_color = "#8e44ad"
    if qdev_ip:
        try:
            q_ip_obj = ipaddress.IPv4Address(qdev_ip)
            for net in subnets.keys():
                if q_ip_obj in ipaddress.IPv4Network(net):
                    qdev_target_net = net
                    break
        except: pass

    margin_x = 80
    backbone_start_y = 120
    backbone_spacing = 50
    
    for i, net in enumerate(subnets.keys()):
        subnets[net]["y"] = backbone_start_y + (i * backbone_spacing)
        
    nodes_start_y = backbone_start_y + (len(subnets) * backbone_spacing) + 80
    
    node_w = 340
    node_h = 160
    node_spacing = 80
    qdev_w = 260
    
    total_elem_w = len(n_list) * node_w + (len(n_list) - 1) * node_spacing
    if qdev_ip: total_elem_w += node_spacing + qdev_w
    
    base_width = margin_x * 2 + total_elem_w
    width = max(1600, base_width)
    
    max_disks = max([len(n.hw_data.get('disks', [])) for n in n_list]) if n_list else 0
    disk_rows = (max_disks // 4) + 1
    
    cartouche_y = nodes_start_y + node_h + (disk_rows * 65) + 60
    cartouche_h = 70 + ((len(n_list) + (1 if qdev_ip else 0)) * 30)
    
    height = cartouche_y + cartouche_h + 80

    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 {width} {height}" style="background-color:#f4f5f7; font-family:sans-serif;">']
    
    # Balanced logos
    svg.append(f'<image href="{p_url}" x="{margin_x}" y="30" height="36" width="180" preserveAspectRatio="xMinYMid meet"/>')
    svg.append(f'<image href="{d_url}" x="{width - margin_x - 180}" y="30" height="36" width="180" preserveAspectRatio="xMaxYMid meet"/>')
    svg.append(f'<text x="{width/2}" y="60" fill="#2c3e50" font-size="28" font-weight="bold" text-anchor="middle">CLUSTER ARCHITECTURE: <tspan fill="#3498db">{escape_xml(cluster_name)}</tspan></text>')

    # Backbones
    for net, info in subnets.items():
        y = info["y"]
        color = info["color"]
        labels_str = " | ".join(sorted(list(info["labels"])))
        svg.append(f'<line x1="{margin_x}" y1="{y}" x2="{width-margin_x}" y2="{y}" stroke="{color}" stroke-width="6" stroke-linecap="round"/>')
        svg.append(f'<text x="{margin_x}" y="{y - 10}" fill="{color}" font-size="14" font-weight="bold">{net} - {escape_xml(labels_str)}</text>')

    start_x = margin_x + (width - margin_x*2 - total_elem_w) / 2

    # QDevice Render
    if qdev_ip:
        qx = start_x + len(n_list) * (node_w + node_spacing)
        qy = nodes_start_y
        
        if qdev_target_net:
            target_y = subnets[qdev_target_net]["y"]
            qdev_target_color = subnets[qdev_target_net]["color"]
            svg.append(f'<line x1="{qx + qdev_w/2}" y1="{target_y}" x2="{qx + qdev_w/2}" y2="{qy}" stroke="{qdev_target_color}" stroke-width="3" stroke-dasharray="6,6"/>')
            svg.append(f'<circle cx="{qx + qdev_w/2}" cy="{target_y}" r="5" fill="{qdev_target_color}"/>')

        display_name = qdev_hostname if qdev_hostname and qdev_hostname != qdev_ip else "QDEVICE"
        svg.append(f'''
        <rect x="{qx}" y="{qy}" width="{qdev_w}" height="{node_h}" rx="12" fill="#ffffff" stroke="#8e44ad" stroke-width="3" filter="drop-shadow(0px 8px 15px rgba(0,0,0,0.1))"/>
        <rect x="{qx}" y="{qy}" width="{qdev_w}" height="50" rx="12" fill="#8e44ad"/>
        <rect x="{qx}" y="{qy+25}" width="{qdev_w}" height="25" fill="#8e44ad"/>
        <text x="{qx + qdev_w/2}" y="{qy + 33}" fill="#ffffff" font-size="22" font-weight="900" text-anchor="middle">{escape_xml(display_name.upper())}</text>
        
        <text x="{qx + qdev_w/2}" y="{qy + 85}" fill="#34495e" font-size="14" font-weight="bold" text-anchor="middle">WITNESS TIE-BREAKER</text>
        <text x="{qx + qdev_w/2}" y="{qy + 115}" fill="{qdev_target_color}" font-size="16" font-weight="bold" text-anchor="middle">IP: {qdev_ip}</text>
        ''')

    # Nodes Render
    for idx, n in enumerate(n_list):
        nx = start_x + idx * (node_w + node_spacing)
        ny = nodes_start_y
        hw = n.hw_data
        
        bridge_count = len(hw.get('bridges', []))
        if bridge_count == 1: br_offsets = [node_w / 2]
        elif bridge_count > 1: 
            space = (node_w - 80) / (bridge_count - 1)
            br_offsets = [40 + i * space for i in range(bridge_count)]
        else: br_offsets = []

        # Network Links & Badges
        for b_idx, br in enumerate(hw.get('bridges', [])):
            if br.get('ip'):
                try:
                    net = str(ipaddress.IPv4Interface(br['ip']).network)
                    target_y = subnets[net]["y"]
                    color = subnets[net]["color"]
                    lx = nx + br_offsets[b_idx]
                    
                    svg.append(f'<line x1="{lx}" y1="{target_y}" x2="{lx}" y2="{ny}" stroke="{color}" stroke-width="3" stroke-dasharray="6,6"/>')
                    svg.append(f'<circle cx="{lx}" cy="{target_y}" r="5" fill="{color}"/>')
                    
                    ports_str = escape_xml(br.get("ports", ""))
                    if not ports_str: ports_str = "NONE"
                    bond_slaves = escape_xml(br.get("bond_slaves", ""))
                    
                    is_bond = ports_str.startswith("bond") or " " in ports_str
                    t_color = "#8e44ad" if is_bond else "#3498db"
                    
                    b_width = max(50, len(ports_str) * 7.5)
                    if is_bond and bond_slaves:
                        b_width = max(b_width, len(bond_slaves) * 6 + 10)
                    
                    box_h = 45 if (is_bond and bond_slaves) else 35
                    
                    svg.append(f'<rect x="{lx - 35}" y="{ny - 10 - box_h}" width="70" height="{box_h}" rx="4" fill="#ffffff" stroke="{color}" stroke-width="2"/>')
                    svg.append(f'<text x="{lx}" y="{ny - 10 - box_h + 16}" fill="{color}" font-size="12" font-weight="bold" text-anchor="middle">{escape_xml(br["name"])}</text>')
                    
                    svg.append(f'<rect x="{lx - b_width/2}" y="{ny - 10 - box_h + 22}" width="{b_width}" height="13" rx="3" fill="{t_color}"/>')
                    svg.append(f'<text x="{lx}" y="{ny - 10 - box_h + 32}" fill="#ffffff" font-size="10" font-weight="bold" text-anchor="middle">{ports_str}</text>')
                    
                    if is_bond and bond_slaves:
                        svg.append(f'<text x="{lx}" y="{ny - 3}" fill="#7f8c8d" font-size="9" text-anchor="middle">{bond_slaves}</text>')
                except: pass

        mgt_c = "#34495e"
        sync_c = "#34495e"
        for net, info in subnets.items():
            try:
                if ipaddress.IPv4Address(n.ip) in ipaddress.IPv4Network(net): mgt_c = info["color"]
            except: pass
            try:
                if ipaddress.IPv4Address(n.corosync_ip) in ipaddress.IPv4Network(net): sync_c = info["color"]
            except: pass

        # Node Container
        svg.append(f'''
        <rect x="{nx}" y="{ny}" width="{node_w}" height="{node_h}" rx="12" fill="#ffffff" stroke="#3498db" stroke-width="3" filter="drop-shadow(0px 8px 15px rgba(0,0,0,0.1))"/>
        <rect x="{nx}" y="{ny}" width="{node_w}" height="50" rx="12" fill="#3498db"/>
        <rect x="{nx}" y="{ny+25}" width="{node_w}" height="25" fill="#3498db"/>
        <text x="{nx + node_w/2}" y="{ny + 33}" fill="#ffffff" font-size="22" font-weight="900" text-anchor="middle">{escape_xml(n.hostname)}</text>
        
        <text x="{nx + node_w/2}" y="{ny + 85}" fill="#34495e" font-size="16" font-weight="bold" text-anchor="middle">MGT: <tspan fill="{mgt_c}">{n.ip}</tspan></text>
        <text x="{nx + node_w/2}" y="{ny + 115}" fill="#34495e" font-size="16" font-weight="bold" text-anchor="middle">SYNC: <tspan fill="{sync_c}">{n.corosync_ip}</tspan></text>
        ''')

        # External Disks (Icons with OS tag color shifting)
        disk_start_y = ny + node_h + 30
        disks = hw.get('disks', [])
        if disks:
            svg.append(f'<text x="{nx + node_w/2}" y="{disk_start_y - 10}" fill="#e67e22" font-size="12" font-weight="bold" text-anchor="middle">LOCAL RAW STORAGE</text>')
            for i, disk in enumerate(disks):
                row = i // 4
                col = i % 4
                dx = nx + 15 + col * 80
                dy = disk_start_y + row * 65
                dname = disk["name"].replace("/dev/", "")
                
                is_os = disk.get('is_os', False)
                os_suffix = " (OS)" if is_os else ""
                
                svg.append(f'<g><title>{escape_xml(disk["name"])} - {escape_xml(disk["model"])}</title>')
